{
  "name": "gestor-agro",
  "version": "4.0.0",
  "description": "Gestor Agro desktop com Electron + PostgreSQL",
  "main": "codigo-fonte/principal/main.js",
  "scripts": {
    "start":     "electron .",
    "build:exe": "electron-builder --win nsis",
    "pack":      "electron-builder --dir",
    "test":      "node testes/inmet.test.js"
  },
  "dependencies": {
    "dotenv":   "^16.4.5",
    "express":  "^4.21.0",
    "pg":       "^8.12.0"
  },
  "devDependencies": {
    "electron":         "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId":       "com.gestoragro.desktop",
    "productName": "Gestor Agro",
    "asar":        true,
    "files": [
      "codigo-fonte/**/*",
      "configuracoes/.env.exemplo",
      "package.json",
      ".env"
    ],
    "directories": {
      "output":          "distribuicao",
      "buildResources":  "recursos-build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "executableName": "GestorAgro"
    },
    "nsis": {
      "oneClick":                       false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut":          true,
      "createStartMenuShortcut":        true
    },
    "artifactName": "GestorAgro-Setup-${version}.${ext}"
  }
}
